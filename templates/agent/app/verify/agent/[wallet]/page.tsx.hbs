/**
 * Public agent verification page.
 * Anyone can visit /verify/agent/<wallet> to confirm an agent's
 * identity, check its current status, and review its capabilities.
 * Fetches live data from the GitHat public verify API.
 */

const GITHAT_API = 'https://api.githat.io';

{{#if typescript}}
interface AgentVerify {
  verified: boolean;
  name: string;
  wallet: string;
  chainId: number;
  status: 'active' | 'paused' | 'revoked' | 'pending';
  verifiedSince: string;
  lastActivity: string;
  capabilities: string[];
  actionsLast24h: number;
  verificationUrl: string;
}
{{/if}}

async function fetchAgent(wallet{{#if typescript}}: string{{/if}}){{#if typescript}}: Promise<AgentVerify | null>{{/if}} {
  try {
    const res = await fetch(`${GITHAT_API}/verify/agent/${wallet}`, {
      next: { revalidate: 60 },
    });
    if (!res.ok) return null;
    return res.json();
  } catch {
    return null;
  }
}

export default async function VerifyAgentPage({ params }{{#if typescript}}: { params: Promise<{ wallet: string }> }{{/if}}) {
  const { wallet } = await params;
  const agent = await fetchAgent(wallet);

  if (!agent?.verified) {
    return (
      <main style=\{{
        minHeight: '100vh',
        background: '#0a0a0a',
        color: '#fafafa',
        fontFamily: "'Inter', system-ui, sans-serif",
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        padding: '4rem 1rem',
      }}>
        <div style=\{{ textAlign: 'center' }}>
          <p style=\{{ fontSize: '1.125rem', color: '#a1a1aa', marginBottom: '0.5rem' }}>Agent not found</p>
          <p style=\{{ fontSize: '0.875rem', color: '#52525b', fontFamily: "'JetBrains Mono', monospace", wordBreak: 'break-all' }}>
            {wallet}
          </p>
        </div>
      </main>
    );
  }

  const statusColor = {
    active:  '#16a34a',
    paused:  '#d97706',
    revoked: '#dc2626',
    pending: '#6366f1',
  }[agent.status] ?? '#71717a';

  return (
    <main style=\{{
      minHeight: '100vh',
      background: '#0a0a0a',
      color: '#fafafa',
      fontFamily: "'Inter', system-ui, sans-serif",
      display: 'flex',
      alignItems: 'flex-start',
      justifyContent: 'center',
      padding: '4rem 1rem',
    }}>
      <div style=\{{ width: '100%', maxWidth: '36rem' }}>
        {/* Header */}
        <div style=\{{ marginBottom: '2rem', textAlign: 'center' }}>
          <div style=\{{
            display: 'inline-flex',
            alignItems: 'center',
            gap: '0.5rem',
            padding: '0.375rem 0.875rem',
            borderRadius: '9999px',
            background: statusColor + '22',
            border: `1px solid ${statusColor}44`,
            marginBottom: '1.5rem',
          }}>
            <span style=\{{ width: '0.5rem', height: '0.5rem', borderRadius: '9999px', background: statusColor, display: 'inline-block' }} />
            <span style=\{{ fontSize: '0.75rem', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.08em', color: statusColor }}>
              {agent.status}
            </span>
          </div>
          <h1 style=\{{ fontSize: '1.75rem', fontWeight: 700, marginBottom: '0.5rem' }}>{agent.name}</h1>
          <p style=\{{ fontFamily: "'JetBrains Mono', monospace", fontSize: '0.8125rem', color: '#71717a', wordBreak: 'break-all' }}>
            {agent.wallet}
          </p>
        </div>

        {/* Stats */}
        <div style=\{{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '1rem', marginBottom: '1.5rem' }}>
          {[
            { label: 'Actions (24h)', value: agent.actionsLast24h },
            { label: 'Verified since', value: new Date(agent.verifiedSince).toLocaleDateString() },
          ].map(({ label, value }) => (
            <div key={label} style=\{{
              padding: '1.25rem',
              borderRadius: '0.75rem',
              border: '1px solid #27272a',
              background: '#18181b',
            }}>
              <div style=\{{ fontSize: '0.75rem', color: '#71717a', marginBottom: '0.375rem' }}>{label}</div>
              <div style=\{{ fontSize: '1.125rem', fontWeight: 600 }}>{value}</div>
            </div>
          ))}
        </div>

        {/* Capabilities */}
        {agent.capabilities.length > 0 && (
          <div style=\{{
            padding: '1.25rem',
            borderRadius: '0.75rem',
            border: '1px solid #27272a',
            background: '#18181b',
            marginBottom: '1.5rem',
          }}>
            <h2 style=\{{ fontSize: '0.875rem', fontWeight: 600, color: '#a1a1aa', textTransform: 'uppercase', letterSpacing: '0.06em', marginBottom: '1rem' }}>
              Capabilities
            </h2>
            <div style=\{{ display: 'flex', flexWrap: 'wrap', gap: '0.5rem' }}>
              {agent.capabilities.map((cap) => (
                <span key={cap} style=\{{
                  padding: '0.375rem 0.75rem',
                  borderRadius: '0.375rem',
                  border: '1px solid #3f3f46',
                  fontSize: '0.8125rem',
                  fontFamily: "'JetBrains Mono', monospace",
                  color: '#a1a1aa',
                }}>
                  {cap}
                </span>
              ))}
            </div>
          </div>
        )}

        {/* Footer */}
        <div style=\{{ textAlign: 'center' }}>
          <p style=\{{ fontSize: '0.75rem', color: '#52525b' }}>
            Verified by{' '}
            <a href="https://githat.io" style=\{{ color: '#6366f1', textDecoration: 'none' }}>
              GitHat Identity
            </a>
            {agent.lastActivity && (
              <> · Last active {new Date(agent.lastActivity).toLocaleDateString()}</>
            )}
          </p>
        </div>
      </div>
    </main>
  );
}
