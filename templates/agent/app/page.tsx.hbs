        <div>
          <h1 style=\{{
            fontFamily: 'var(--font-wordmark)',
            fontSize: 'clamp(2rem, 5vw, 3.25rem)',
            lineHeight: 1.1,
            marginBottom: 'var(--space-4)',
          }}>
